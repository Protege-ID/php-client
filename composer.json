{
  "name": "protege-id/php-client",
  "description": "ProtegeId PHP SDK",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.0",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^4.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/php-code-coverage": "^9.2"
  },
  "scripts": {
    "test": "./vendor/bin/phpunit",
    "test:coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit -c phpunit.coverage.xml --coverage-html coverage --coverage-clover coverage/clover.xml"
  },
  "autoload": {
    "psr-4": {
      "ProtegeId\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ProtegeId\\Tests\\": "tests/"
    }
  }
}
