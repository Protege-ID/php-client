<?xml version="1.0"?>
<ruleset name="ProtegeId PHP SDK">
    <description>PHP_CodeSniffer ruleset for the ProtegeId PHP SDK.</description>

    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="basepath" value="."/>
    <arg name="cache" value=".phpcs-cache"/>

    <file>src</file>
    <file>tests</file>

    <exclude-pattern>vendor/*</exclude-pattern>

    <rule ref="PSR12"/>
</ruleset>
